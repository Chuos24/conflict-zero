# App
APP_NAME=Conflict Zero API
DEBUG=true
VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conflictzero

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# APIs Externas (Dejolecta u otras)
DECOLECTA_API_KEY=
DECOLECTA_BASE_URL=https://api.decolecta.com/v1

# Scoring Weights
SCORE_SUNAT_WEIGHT=0.30
SCORE_OSCE_WEIGHT=0.40
SCORE_ML_WEIGHT=0.30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
