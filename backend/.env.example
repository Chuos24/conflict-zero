# Variables de Entorno - Backend

# Database (SQLite para dev, PostgreSQL para prod)
# DATABASE_URL=sqlite:///./conflictzero.db
DATABASE_URL=postgresql://user:password@localhost:5432/conflictzero

# Seguridad (genera una clave fuerte: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# APIs Externas
# Obtén tu API key en: https://peruapi.com
PERU_API_KEY=d02bb5a71984e759885a4e47a575715c

# OSCE/TCE (placeholders por ahora)
OSCE_API_KEY=
TCE_API_KEY=

# Configuración
ENVIRONMENT=development
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis (opcional)
REDIS_URL=redis://localhost:6379/0
USE_CACHE=false
