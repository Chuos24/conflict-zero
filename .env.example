# ============================================
# Conflict Zero - Environment Variables
# ============================================
# Copy this file to .env and update the values for your environment

# ============================================
# Application Settings
# ============================================
APP_NAME=Conflict Zero
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_USER=conflictzero
POSTGRES_PASSWORD=changeme
POSTGRES_DB=conflictzero
POSTGRES_PORT=5432

# Database connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================
# Cache (Redis)
# ============================================
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# ============================================
# Security
# ============================================
# Generate a strong secret key for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS Settings
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Backend Service
# ============================================
BACKEND_PORT=8000
BACKEND_BUILD_TARGET=development

# ============================================
# Frontend Service
# ============================================
FRONTEND_PORT=3000
FRONTEND_BUILD_TARGET=development
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# API URLs
API_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth.js
# Generate a strong secret for production:
# openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Public Environment Variables
NEXT_PUBLIC_APP_NAME=Conflict Zero
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ============================================
# Nginx (Optional - use with --profile nginx)
# ============================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# Monitoring & Observability (Optional)
# ============================================
# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Prometheus
ENABLE_METRICS=false
METRICS_PORT=9090

# ============================================
# Email/SMTP (Optional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@conflictzero.local
SMTP_TLS=true

# ============================================
# Third-party Services (Optional)
# ============================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
