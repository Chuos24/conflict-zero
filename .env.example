# ============================================================
# Conflict Zero API - Environment Variables (FastAPI backend)
# ============================================================
# Copy this file to .env and fill in real values for your environment.
# NEVER commit a real .env file or real secret values to git.
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=Conflict Zero API
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production            # development | production
ALLOWED_HOSTS=*                   # comma-separated list, or * 
USE_CACHE=false

# ------------------------------------------------------------
# Database (PostgreSQL) - REQUIRED
# ------------------------------------------------------------
# Full SQLAlchemy connection string. On Render, copy the Internal
# Database URL. Falls back to local sqlite if unset (dev only).
DATABASE_URL=postgresql://user:password@host:5432/conflictzero

# ------------------------------------------------------------
# Cache (Redis) - optional (only used when USE_CACHE=true)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Security / JWT - REQUIRED
# ------------------------------------------------------------
# CRITICAL: set a strong, unique SECRET_KEY in production.
# If left as the placeholder, JWT tokens can be forged.
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ------------------------------------------------------------
# Founder bootstrap + Admin access - REQUIRED for admin features
# ------------------------------------------------------------
# Used by the founder login path and admin-protected endpoints.
# There are NO hardcoded fallbacks in code - these MUST be set,
# otherwise founder login and admin endpoints will not work.
FOUNDER_EMAIL=founder@example.com
FOUNDER_PASSWORD=CHANGE_ME_strong_password
ADMIN_TOKEN=CHANGE_ME_strong_random_admin_token

# ------------------------------------------------------------
# Scoring weights (LegalBot) - optional (defaults shown)
# ------------------------------------------------------------
SCORE_SUNAT_WEIGHT=0.30
SCORE_OSCE_WEIGHT=0.40
SCORE_ML_WEIGHT=0.30

# ------------------------------------------------------------
# Rate limiting - optional (defaults shown)
# ------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ------------------------------------------------------------
# Payments (Stripe) - required for checkout/billing
# ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------
# AWS S3 (certificate storage) - optional
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=conflictzero-certificados-prod

# ============================================================
# SUNAT / RUC Data Providers
# ============================================================
# At least one paid provider is recommended; apis.net.pe is the
# free fallback. Leave any provider blank to disable that source.
# ------------------------------------------------------------

# Factiliza - primary SUNAT RUC source. Token at https://factiliza.com
FACTILIZA_TOKEN=

# PeruAPI - alternative source. Token at https://peruapi.com
PERUAPI_TOKEN=
PERU_API_KEY=

# Decolecta - alternative source
DECOLECTA_API_KEY=
DECOLECTA_BASE_URL=https://api.decolecta.com

# APIPeru.dev - alternative source. Token at https://apiperu.dev
APIPERU_TOKEN=
APIPERU_DEV_TOKEN=

# apis.net.pe - free SUNAT source (rate limited)
APIS_NET_PE_TOKEN=

# BuscarUC - alternative source
BUSCARUC_TOKEN=

# ============================================================
# Email (optional) - SES, SendGrid, or SMTP
# ============================================================
EMAIL_FROM=noreply@czperu.com
EMAIL_FROM_NAME=Conflict Zero
EMAIL_USE_SES=false
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
